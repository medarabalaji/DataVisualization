<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.layout.BorderPane?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.Pane?>

<?import io.github.palexdev.materialfx.controls.MFXComboBox?>
<?import io.github.palexdev.materialfx.controls.MFXButton?>
<?import io.github.palexdev.materialfx.controls.MFXTextField?>
<?import io.github.palexdev.materialfx.controls.MFXScrollPane?>
<BorderPane xmlns:fx="http://javafx.com/fxml" id="mainPanel" fx:id="totalScreen"  fx:controller="com.ramedis.datavisualization.DataVisualizerController" stylesheets="@styles/style.css">
    <top>
        <VBox spacing="20">
            <padding>
                <Insets top="10" right="10" bottom="0" left="10"/>
            </padding>
            <BorderPane prefHeight="100" styleClass="card">
                <padding>
                    <Insets top="10" right="10" bottom="10" left="10"/>
                </padding>
                <left>
                    <Label styleClass="DVlogo" text="Data Visualizer"/>
                </left>
                <center >
                    <HBox alignment="CENTER" spacing="20">
                        <HBox spacing="10">
                            <Label styleClass="ctgLabel" text="Category"/>
                            <MFXComboBox id="categoryCmb" fx:id="categoryCmb" translateY="10" onAction="#categorySelectionClick" />
                        </HBox>
                        <HBox spacing="10">
                            <Label styleClass="typeLabel" text="Types" />
                            <MFXComboBox id="implementCmb" fx:id="implementCmb" translateY="10"  onAction="#implementationSelectedCombo" disable="true" />
                        </HBox>
                    </HBox>
                </center>
                <right>
                    <VBox>
                    <MFXButton id="themeBtn" text="Theme" translateY="13" styleClass="themeBtn" fx:id="themeBtn" prefWidth="100" prefHeight="40" rippleAnimateBackground="true" buttonType="RAISED" maxWidth="150"  onAction="#changeBgBtn">
                        <graphic>
                            <FontIcon iconLiteral="mdi2t-theme-light-dark" fx:id="themeLogoColor"/>
                        </graphic>
                    </MFXButton>
                    </VBox>
                </right>

            </BorderPane>


            <BorderPane prefHeight="100" styleClass="card">
                <padding>
                    <Insets top="10" right="10" bottom="0" left="10"/>
                </padding>
                <left>
                    <HBox spacing="20">
                        <Label styleClass="sizeLabel" text="Capacity"/>
                        <MFXTextField id="sizeTextField" promptText="Enter Size" fx:id="sizeField"/>
                    </HBox>
                </left>
                <center>
                    <HBox spacing="50" alignment="CENTER">
                        <MFXComboBox id="dataTypeCmb" styleClass="dataTypeCmb" fx:id="dataTypeCmb" onAction="#dataTypeSelectionClick" />
                        <HBox id="keyValueTypeCmb" fx:id="keyValueTypeCmb" spacing="30" >
                            <Label styleClass="keyLabel" text="Key : " />
                            <MFXComboBox id="keyTypeCmb" fx:id="keyTypeCmb"  onAction="#keyTypeSelectionClick" />
                            <Label styleClass="valueLabel" text="Value : " />
                            <MFXComboBox id="valueTypeCmb" fx:id="valueTypeCmb" onAction="#valueTypeSelectionClick"/>
                        </HBox>

                    </HBox>
                </center>
                <right>
                    <MFXButton id="applyBtn" prefWidth="100" prefHeight="40" buttonType="RAISED" computeRadiusMultiplier="true" depthLevel="LEVEL1" rippleAnimateBackground="true" rippleAnimateShadow="true" rippleAnimationSpeed="20" rippleColor="green" rippleRadius="20" fx:id="applyBtn" text="Apply" onAction="#applyBtn">
                        <graphic>
                            <FontIcon iconLiteral="mdi2a-account-alert" iconColor="white" iconSize="20"/>
                        </graphic>
                    </MFXButton>
                </right>
            </BorderPane>
        </VBox>
    </top>
    <left>
        <VBox>
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
            <children>
        <StackPane styleClass="card" prefHeight="450">

            <VBox fx:id="operationPanelCard" visible="false" spacing="20">
                <Label id="controlPanel" text="Controls"/>
                <MFXTextField id="arrayInpField" fx:id="inpField" promptText="Enter Value"/>
                <VBox spacing="20" id="arrayBtns">
                    <HBox spacing="20">
                        <MFXButton onAction="#onAdd" text="Add" >
                            <graphic>
                                <FontIcon iconLiteral="mdi2p-plus-thick" iconColor="white"/>
                            </graphic>
                        </MFXButton>
                        <MFXButton onAction="#removeBtn" text="Remove">
                            <graphic>
                                <FontIcon iconLiteral="mdi2m-minus-thick" iconColor="white"/>
                            </graphic>
                        </MFXButton>
                    </HBox>
                    <HBox spacing="20">
                        <MFXButton onAction="#searchBtn" text="Search">
                            <graphic>
                                <FontIcon iconLiteral="mdi2m-magnify" iconColor="white"/>
                            </graphic>
                        </MFXButton>
                        <MFXButton onAction="#clearBtn" text="Clear" >
                            <graphic>
                                <FontIcon iconLiteral="mdi2c-close" iconColor="white"/>
                            </graphic>
                        </MFXButton>
                    </HBox>
                </VBox>
            </VBox>
            <VBox fx:id="operationPanelCard3" visible="false" spacing="20">
                <Label id="setControlLabel" text="Controls" />
                <MFXTextField id="setInpField" fx:id="setInpField" promptText="Enter Value" style="-fx-text-fill: #EC641C;-fx-font-size: 20"/>
                <VBox spacing="20" id="setBtns">
                    <HBox spacing="20">
                        <MFXButton onAction="#onSetAdd" text="Add" style="-fx-font-size: 18;-fx-text-fill: #000000; ">
                            <graphic>
                                <FontIcon iconLiteral="mdi2p-plus-thick" iconColor="white"/>
                            </graphic>
                        </MFXButton>
                        <MFXButton onAction="#removeSetBtn" text="Remove" style="-fx-font-size: 18;-fx-text-fill: #000000; ">
                            <graphic>
                                <FontIcon iconLiteral="mdi2m-minus-thick" iconColor="white"/>
                            </graphic>
                        </MFXButton>
                    </HBox>
                    <HBox spacing="20">
                        <MFXButton onAction="#searchSetBtn" text="Search" style="-fx-font-size: 18;-fx-text-fill: #000000; ">
                            <graphic>
                                <FontIcon iconLiteral="mdi2m-magnify" iconColor="white"/>
                            </graphic>
                        </MFXButton>
                        <MFXButton onAction="#clearSetBtn" text="Clear" style="-fx-font-size: 18;-fx-text-fill: #000000; ">
                            <graphic>
                                <FontIcon iconLiteral="mdi2c-close" iconColor="white"/>
                            </graphic>
                        </MFXButton>
                    </HBox>
                </VBox>

            </VBox>
            <VBox fx:id="operationPanelCard2" spacing="20" visible="false">

                <Label id="mapControlLabel" text="Controls" />
                <HBox spacing="20">
                    <MFXTextField id="mapKeyField" fx:id="keyField" promptText="Enter Key" style="-fx-text-fill: #EC641C;-fx-font-size: 20"/>
                    <Label text=" : "  textAlignment="RIGHT" style="-fx-font-size: 30; -fx-text-fill: #aaaaaa;"/>
                    <MFXTextField id="mapValueField" fx:id="valueField" promptText="Enter Value" style="-fx-text-fill: #EC641C;-fx-font-size: 20"/>
                </HBox>
                <VBox spacing="20" id="mapBtns">
                    <HBox spacing="20">
                        <MFXButton onAction="#putBtn" text="Put" style="-fx-font-size: 18;-fx-text-fill: #000000; "/>
                        <MFXButton onAction="#mapRemoveBtn" text="Remove" style="-fx-font-size: 18;-fx-text-fill: #000000; "/>
                    </HBox>
                    <HBox spacing="20">
                        <MFXButton onAction="#mapSearchBtn" text="Search" style="-fx-font-size: 18;-fx-text-fill: #000000; "/>
                        <MFXButton onAction="#mapClearBtn" text="Clear" style="-fx-font-size: 18;-fx-text-fill: #000000; "/>
                    </HBox>
                </VBox>
            </VBox>
        </StackPane>
            </children>
        </VBox>
    </left>
    <center>
        <VBox>
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
        <children>
        <BorderPane styleClass="card">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
            <center>
            <VBox>
                <Label id="visualizationPanel" text="Visualization Panel"/>
<!--                <Label text="Elements rendered as boxes or cards"/>-->

                <MFXScrollPane id="visualScroll" fx:id="scrollPane"  fitToWidth="false" fitToHeight="true" prefHeight="450" thumbColor="green" thumbHoverColor="crimson" trackColor="red">
                    <content>
                        <StackPane alignment="CENTER">
                        <HBox spacing="10" fx:id="visualizationPanelCard">
                            <padding>
                                <Insets top="10" left="10" right="20" bottom="10"/>
                            </padding>
                        </HBox>
                        </StackPane>
                    </content>
                </MFXScrollPane>

            </VBox>

            </center>
        </BorderPane>
        </children>
        </VBox>
    </center>
    <bottom>
        <VBox>
            <padding>
                <Insets left="10" bottom="10" right="10" top="0"/>
            </padding>
        <children>
        <VBox styleClass="card" fx:id="logEventPanel">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
            <Label id="logLabel" text="Log Events"/>
            <MFXScrollPane fx:id="logEventScrollPanel" onScrollFinished="#scrollFinish" prefHeight="350">
                <content>
                    <VBox fx:id="logEventsField">

                    </VBox>
                </content>
            </MFXScrollPane>
        </VBox>
        </children>
        </VBox>
    </bottom>
</BorderPane>
